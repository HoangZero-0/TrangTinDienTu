<!DOCTYPE html>
<html lang="en">

<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1" />
	<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
	<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
	<title><%= title %> - Trang tin điện tử</title>
</head>

<body>
	<div class="container">
		<!-- Menu ngang -->
		<%- include('navbar') %>
		
		<!-- Nội dung chính -->
		<div class="card mt-3">
			<div class="card-header"><%= title %></div>
			<div class="card-body mb-0 p-3">
				<div class="input-group mb-3 w-50 ms-auto">
					<input type="text" id="searchFilter" class="form-control" placeholder="Tìm kiếm bình luận...">
					<button class="btn btn-outline-secondary" type="button" id="btnSearch"><i class="bi bi-search"></i></button>
				</div>
				<table class="table table-bordered table-hover table-sm mb-0">
					<thead>
						<tr>
							<th width="5%" class="text-center">#</th>
							<th width="15%">Người gửi</th>
							<th width="20%">Bài viết</th>
							<th>Nội dung</th>
							<th width="12%" class="text-center">Trạng thái</th>
							<th width="10%" class="text-center">Ngày gửi</th>
							<th width="8%" class="text-center">Hành động</th>
						</tr>
					</thead>
					<tbody>
						<% if(binhluan.length === 0) { %>
							<tr>
								<td colspan="7" class="text-center text-muted p-3">Chưa có bình luận nào.</td>
							</tr>
						<% } else { %>
							<% binhluan.forEach((bl, index) => { %>
								<% if(bl.TaiKhoan && bl.BaiViet) { %>
								<tr>
									<td class="text-center align-middle"><%= index + 1 %></td>
									<td class="align-middle"><%= bl.TaiKhoan.HoVaTen %></td>
									<td class="align-middle"><a href="/baiviet/chitiet/<%= bl.BaiViet._id %>" target="_blank"><%= bl.BaiViet.TieuDe %></a></td>
									<td class="align-middle text-truncate" style="max-width: 250px;"><%= bl.NoiDung %></td>
									<td class="text-center align-middle">
										<% if(bl.KiemDuyet === 1) { %>
											<form action="/binhluan/duyet/<%= bl._id %>" method="POST" style="display:inline;"><button type="submit" class="btn btn-sm btn-link p-0" title="Ẩn bình luận"><span class="badge bg-success">Đang hiển thị</span></button></form>
										<% } else { %>
											<form action="/binhluan/duyet/<%= bl._id %>" method="POST" style="display:inline;"><button type="submit" class="btn btn-sm btn-link p-0" title="Duyệt hiển thị"><span class="badge bg-secondary">Đang ẩn</span></button></form>
										<% } %>
									</td>
									<td class="text-center align-middle"><%= new Date(bl.NgayBinhLuan).toLocaleDateString('vi-VN') %></td>
									<td class="text-center align-middle">
										<form action="/binhluan/xoa/<%= bl._id %>" method="POST" style="display:inline;" onsubmit="return confirm('Bạn có muốn xóa bình luận này không?');">
											<button type="submit" class="btn btn-sm btn-link p-0 text-danger"><i class="bi bi-trash"></i></button>
										</form>
									</td>
								</tr>
								<% } %>
							<% }); %>
						<% } %>
					</tbody>
				</table>
			</div>
		</div>
		
		<!-- Footer -->
		<%- include('footer') %>
	</div>
	
	<%- include('javascript') %>
</body>

</html>
