<!DOCTYPE html>
<html lang="en">

<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1" />
	<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
	<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
	<title><%= title %> - Trang tin điện tử</title>
</head>

<body>
	<div class="container">
		<!-- Menu ngang -->
		<%- include('navbar') %>
		
		<!-- Nội dung chính -->
		<div class="card mt-3">
			<div class="card-header"><%= title %></div>
			<div class="card-body">
				<form action="/taikhoan/hoso" method="post" enctype="multipart/form-data" class="needs-validation" novalidate>
					<div class="mb-3">
						<label for="TenDangNhap" class="form-label">Tên đăng nhập</label>
						<input type="text" class="form-control" id="TenDangNhap" value="<%= taikhoan.TenDangNhap %>" disabled />
					</div>
					
					<div class="mb-3">
						<label for="HoVaTen" class="form-label">Họ và tên</label>
						<input type="text" class="form-control" id="HoVaTen" name="HoVaTen" value="<%= taikhoan.HoVaTen %>" required />
					</div>
					
					<div class="mb-3">
						<label for="Email" class="form-label">Email</label>
						<input type="email" class="form-control" id="Email" name="Email" value="<%= taikhoan.Email %>" />
					</div>
					
					<div class="mb-3">
						<label class="form-label" for="HinhAnh">Hình ảnh</label>
						<% if(taikhoan.HinhAnh) { %>
							<img src="<%= taikhoan.HinhAnh %>" id="previewImage" class="img-thumbnail mb-2 d-block" style="max-width: 250px; max-height: 250px; object-fit: cover;" />
						<% } else { %>
							<img src="" id="previewImage" class="img-thumbnail mb-2 d-none" style="max-width: 250px; max-height: 250px; object-fit: cover;" />
						<% } %>
						<input type="file" class="form-control" id="HinhAnh" name="HinhAnh" accept="image/*" onchange="document.getElementById('previewImage').src = window.URL.createObjectURL(this.files[0]); document.getElementById('previewImage').classList.replace('d-none', 'd-block');" />
					</div>
					
					<div class="mb-3">
						<label for="MatKhau" class="form-label">Mật khẩu mới</label>
						<input type="password" class="form-control" id="MatKhau" name="MatKhau" />
						<span class="d-block small text-primary">Bỏ trống nếu muốn giữ nguyên mật khẩu cũ.</span>
					</div>
					
					<div class="mb-3">
						<label for="XacNhanMatKhau" class="form-label">Xác nhận mật khẩu</label>
						<input type="password" class="form-control" id="XacNhanMatKhau" name="XacNhanMatKhau" />
						<span class="d-block small text-primary">Bỏ trống nếu muốn giữ nguyên mật khẩu cũ.</span>
					</div>
					
					<button type="submit" class="btn btn-primary"><i class="bi bi-cloud-arrow-up"></i> Cập nhật hồ sơ</button>
				</form>
			</div>
		</div>
		
		<!-- Footer -->
		<%- include('footer') %>
	</div>
	
	<%- include('javascript') %>
</body>

</html>
