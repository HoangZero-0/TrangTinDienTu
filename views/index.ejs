<!DOCTYPE html>
<html lang="en">

<head>
	<meta charset="utf-8" />
	<meta http-equiv="X-UA-Compatible" content="IE=edge" />
	<meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
	<meta name="description" content="Trang tin điện tử nhiều người xem nhất vũ trụ." />
	<meta name="author" content="Nguyễn Hoàng Thức & Lê Nhật Quang" />
	<title>
		<%= title %> - Trang tin điện tử
	</title>
	<link href="/css/app.css" rel="stylesheet" />
	<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.8.1/font/bootstrap-icons.css">
</head>

<body>
	<%- include('navbar_public') %>
	<main class="main pt-4">
		<div class="container">
			<div class="row">
				<div class="col-md-9">
					<div class="row">
						<% if(typeof baiviet !=="undefined" ) { %>
							<% baiviet.forEach(bv=> { %>
								<div class="col-md-4 mb-4">
									<article class="card h-100 border-0 shadow-sm">
										<a href="/baiviet/chitiet/<%= bv._id %>">
											<img class="card-img-post w-100" src="<%- firstImage(bv.NoiDung) %>" alt="" />
										</a>
										<div class="card-body">
											<a href="/baiviet/chitiet/<%= bv._id %>" class="text-decoration-none text-dark">
												<h4 class="card-title">
													<%= bv.TieuDe %>
												</h4>
											</a>
											<div class="card-meta small mb-2 text-muted">
												<time class="timeago" datetime="<%= bv.NgayDang %>"></time> thuộc 
												<% if(bv.ChuDe) { %>
													<a href="/baiviet/chude/<%= bv.ChuDe._id %>"><%= bv.ChuDe.TenChuDe %></a>
												<% } else { %>
													<span>Chưa phân loại</span>
												<% } %>
											</div>
											<p class="card-text card-text-limit" style="display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;">
												<%= bv.TomTat %>
											</p>
										</div>
									</article>
								</div>
							<% }); %>
						<% } %>
					</div>
					<nav>
						<ul class="pagination justify-content-center">
							<% if (pages > 0) { %>
								<% if (current == 1) { %>
									<li class="page-item disabled"><a class="page-link" href="#">Về trước</a></li>
								<% } else { %>
									<li class="page-item"><a class="page-link" href="/?page=1">Đầu</a></li>
									<li class="page-item"><a class="page-link" href="/?page=<%= Number(current) - 1 %>">Về trước</a></li>
								<% } %>
								
								<% var i = (Number(current) > 3 ? Number(current) - 2 : 1) %>
								<% if (i !== 1) { %>
									<li class="page-item disabled"><a class="page-link" href="#">...</a></li>
								<% } %>
								
								<% for (; i <= (Number(current) + 2) && i <= pages; i++) { %>
									<% if (i == current) { %>
										<li class="page-item active"><a class="page-link" href="#"><%= i %></a></li>
									<% } else { %>
										<li class="page-item"><a class="page-link" href="/?page=<%= i %>"><%= i %></a></li>
									<% } %>
									<% if (i == Number(current) + 2 && i < pages) { %>
										<li class="page-item disabled"><a class="page-link" href="#">...</a></li>
									<% } %>
								<% } %>
								
								<% if (current == pages) { %>
									<li class="page-item disabled"><a class="page-link" href="#">Về sau</a></li>
								<% } else { %>
									<li class="page-item"><a class="page-link" href="/?page=<%= Number(current) + 1 %>">Về sau</a></li>
									<li class="page-item"><a class="page-link" href="/?page=<%= pages %>">Cuối</a></li>
								<% } %>
							<% } %>
						</ul>
					</nav>
				</div>
				<div class="col-md-3 ms-auto">
					<aside class="sidebar">
						<div class="card mb-4">
							<div class="card-body">
								<h4 class="card-title">Giới thiệu</h4>
								<p class="card-text">Đọc tin tức trên trang web này sẽ giúp bạn có cái nhìn khách quan
									về cuộc sống. Đừng quên chia sẻ trang này cho toàn bộ vũ trụ biết nhé. Mến yêu.</p>
							</div>
						</div>
					</aside>
					<aside class="sidebar sidebar-sticky">
						<div class="card mb-4">
							<div class="card-body">
								<h4 class="card-title">Thẻ</h4>
								<% if(typeof chuyenmuc !=="undefined" ) { chuyenmuc.forEach(cd=> { %>
									<a class="btn btn-light btn-sm mb-1" href="/baiviet/chude/<%= cd._id %>">
										<%= cd.TenChuDe %>
									</a>
									<% }); } %>
							</div>
						</div>
						<div class="card mb-4">
							<div class="card-body">
								<h4 class="card-title">Xem nhiều nhất</h4>
								<% if(typeof xemnhieunhat !=="undefined" ) { xemnhieunhat.forEach(bv=> { %>
									<a href="/baiviet/chitiet/<%= bv._id %>" class="d-inline-block mt-3">
										<h4 class="h6">
											<%= bv.TieuDe %>
										</h4>
										<img class="card-img" src="<%- firstImage(bv.NoiDung) %>" alt="" />
									</a>
									<time class="timeago" datetime="<%= bv.NgayDang %>"></time> thuộc <%=
										bv.ChuDe ? bv.ChuDe.TenChuDe : 'Chưa phân loại' %>
										<% }); } %>
							</div>
						</div>
					</aside>
				</div>
			</div>
		</div>
	</main>
	<%- include('footer_public') %>
	<script src="/js/app.js"></script>
	<script src="/js/weather.js"></script>
</body>

</html>