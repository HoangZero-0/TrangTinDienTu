<!DOCTYPE html>
<html lang="en">

<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1" />
	<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
	<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
	<title><%= title %> - Trang tin điện tử</title>
</head>

<body>
	<div class="container">
		<!-- Menu ngang -->
		<%- include('navbar') %>
		
		<!-- Nội dung chính -->
		<div class="card mt-3">
			<div class="card-header"><%= title %></div>
			<div class="card-body table-responsive">
				<div class="row mb-2">
					<div class="col-md-8">
						<a href="/baiviet/them" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Đăng bài viết</a>
					</div>
					<div class="col-md-4">
						<input type="text" id="searchFilter" class="form-control" placeholder="Tìm kiếm bài viết của tôi...">
					</div>
				</div>
				<table class="table table-bordered table-hover table-sm mb-0">
					<thead>
						<tr>
							<th width="5%">#</th>
							<th width="15%">Chủ đề</th>
							<th width="45%">Tiêu đề</th>
							<th width="10%">Ngày đăng</th>
							<th width="10%">Trạng thái</th>
							<th width="5%">Sửa</th>
							<th width="5%">Xóa</th>
						</tr>
					</thead>
					<tbody>
						<% if(baiviet.length === 0) { %>
							<tr>
								<td colspan="7" class="text-center text-muted">Bạn chưa có bài viết nào.</td>
							</tr>
						<% } else { %>
							<% var stt = 1; %>
							<% baiviet.forEach(function(bv){ %>
								<tr>
									<td class="align-middle"><%= stt++ %></td>
									<td class="align-middle small"><%= bv.ChuDe ? bv.ChuDe.TenChuDe : 'Chưa phân loại' %></td>
									<td class="align-middle small"><%= bv.TieuDe %></td>
									<td class="align-middle small"><%= new Date(bv.NgayDang.toISOString()).toLocaleString("vi-VN") %></td>
									<td class="align-middle text-center">
										<% if(bv.KiemDuyet === 1) { %>
											<span class="badge bg-success">Đã duyệt</span>
										<% } else { %>
											<span class="badge bg-warning text-dark">Chờ duyệt</span>
										<% } %>
									</td>
									<td class="align-middle text-center">
										<% if(bv.KiemDuyet === 0) { %>
											<a href="/baiviet/sua/<%= bv._id %>" title="Sửa bài viết"><i class="bi bi-pencil-square"></i></a>
										<% } else { %>
											<span class="text-muted" title="Bài đã duyệt không thể sửa từ đây" style="cursor: not-allowed; opacity: 0.5;"><i class="bi bi-lock-fill"></i></span>
										<% } %>
									</td>
									<td class="align-middle text-center">
										<form action="/baiviet/xoa/<%= bv._id %>" method="POST" style="display:inline;" onsubmit="return confirm('Bạn có muốn xóa bài viết <%= bv.TieuDe %> không?');">
											<button type="submit" class="btn btn-sm btn-link p-0"><i class="bi bi-trash text-danger"></i></button>
										</form>
									</td>
								</tr>
							<% }); %>
						<% } %>
					</tbody>
				</table>
			</div>
		</div>
		
		<!-- Footer -->
		<%- include('footer') %>
	</div>
	
	<%- include('javascript') %>
</body>

</html>