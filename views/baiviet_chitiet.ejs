<!DOCTYPE html>
<html lang="en">

<head>
	<meta charset="utf-8" />
	<meta http-equiv="X-UA-Compatible" content="IE=edge" />
	<meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
	<meta name="description" content="Trang tin điện tử nhiều người xem nhất vũ trụ." />
	<meta name="author" content="Nguyễn Hoàng Thức & Lê Nhật Quang" />
	<title>
		<%= (typeof baiviet !=="undefined" ) ? baiviet.TieuDe : 'N/A' %> - Trang tin điện tử
	</title>
	<link href="/css/app.css" rel="stylesheet" />
	<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.8.1/font/bootstrap-icons.css">
</head>

<body>
	<%- include('navbar_public') %>
	<main class="main pt-4">
		<div class="container">
			<div class="row">
				<div class="col-md-9">
					<% if(typeof baiviet !=="undefined" ) { %>
						<article class="card mb-4">
							<header class="card-header text-center">
								<div class="card-meta">
									<a href="#"><time class="timeago" datetime="<%= baiviet.NgayDang %>"></time></a>
									thuộc <a href="/baiviet/chude/<%= baiviet.ChuDe ? baiviet.ChuDe._id : '#' %>">
										<%= baiviet.ChuDe ? baiviet.ChuDe.TenChuDe : 'Chưa phân loại' %>
									</a>
								</div>
								<a href="post-image.html">
									<h3 class="card-title">
										<%= baiviet.TieuDe %>
									</h3>
								</a>
								<div class="mt-2">
									<% if(typeof session !== "undefined" && session.MaNguoiDung) { %>
										<form action="/baiviet/luu/<%= baiviet._id %>" method="POST" style="display: inline;">
											<% if(daLuu) { %>
												<button type="submit" class="btn btn-outline-danger btn-sm">
													<i class="bi bi-heart-fill"></i> Đã lưu bài viết
												</button>
											<% } else { %>
												<button type="submit" class="btn btn-outline-secondary btn-sm">
													<i class="bi bi-heart"></i> Lưu bài viết
												</button>
											<% } %>
										</form>
									<% } %>
								</div>
							</header>
							<div class="card-body">
								<p style="text-align:justify;"><strong>
										<%= baiviet.TomTat %>
									</strong></p>
								<%- baiviet.NoiDung %>

									<!-- Bài viết liên quan -->
									<% if(typeof baivietlienquan !== "undefined" && baivietlienquan.length > 0) { %>
									<div class="mt-5">
										<hr />
										<h4 class="mb-4">Bài viết liên quan</h4>
										<div class="row">
											<% baivietlienquan.forEach(lq => { %>
											<div class="col-md-3">
												<div class="card mb-3 border-0 shadow-sm h-100">
													<a href="/baiviet/chitiet/<%= lq._id %>">
														<img class="card-img-related w-100" src="<%- firstImage(lq.NoiDung) %>" />
													</a>
													<div class="p-2">
														<h6 class="card-title mb-0" style="font-size: 0.9rem;">
															<a href="/baiviet/chitiet/<%= lq._id %>" class="text-decoration-none text-dark">
																<%= lq.TieuDe %>
															</a>
														</h6>
													</div>
												</div>
											</div>
											<% }); %>
										</div>
									</div>
									<% } %>

									<hr />
									<h3>Bình luận</h3>
									<% if(binhluan.length === 0) { %>
										<p class="text-muted">Chưa có bình luận nào. Hãy là người đầu tiên!</p>
									<% } %>

									<% binhluan.forEach(bl => { %>
									<!-- Bình luận gốc -->
									<div class="mb-4">
										<div class="d-flex p-3 bg-light rounded shadow-sm">
											<div class="text-center">
												<img class="me-3 img-avatar-comment border"
													src="<%= bl.TaiKhoan.HinhAnh || 'https://trangtin-v3-1.onrender.com/images/avatars/1.png' %>"
													width="50" height="50" />
											</div>
											<div class="flex-grow-1">
												<div class="d-flex justify-content-between align-items-center">
													<h6 class="mb-0"><%= bl.TaiKhoan.HoVaTen %></h6>
													<time class="small text-muted" datetime="<%= bl.NgayBinhLuan %>"><%= new Date(bl.NgayBinhLuan).toLocaleString('vi-VN') %></time>
												</div>
												<p class="mt-2 mb-1"><%= bl.NoiDung %></p>
												
												<% if(typeof session !== "undefined" && session.MaNguoiDung) { %>
												<button class="btn btn-sm btn-link p-0 text-decoration-none" type="button" data-bs-toggle="collapse" data-bs-target="#replyForm<%= bl._id %>">
													<i class="bi bi-reply"></i> Trả lời
												</button>
												<!-- Form trả lời -->
												<div class="collapse mt-2" id="replyForm<%= bl._id %>">
													<form action="/binhluan/<%= baiviet._id %>" method="post">
														<input type="hidden" name="BinhLuanCha" value="<%= bl._id %>">
														<div class="input-group">
															<input type="text" name="NoiDung" class="form-control form-control-sm" placeholder="Viết phản hồi..." required>
															<button class="btn btn-sm btn-primary" type="submit">Gửi</button>
															<button class="btn btn-sm btn-outline-secondary" type="button" data-bs-toggle="collapse" data-bs-target="#replyForm<%= bl._id %>">Hủy</button>
														</div>
													</form>
												</div>
												<% } %>
											</div>
										</div>

										<!-- Các phản hồi (Trả lời) -->
										<% if(bl.replies && bl.replies.length > 0) { %>
											<div class="ms-5 mt-2 border-start ps-3">
												<% bl.replies.forEach(reply => { %>
												<div class="d-flex mb-2 p-2 bg-white rounded border shadow-sm">
													<div class="text-center">
														<img class="me-2 img-avatar-comment border"
															src="<%= reply.TaiKhoan.HinhAnh || 'https://trangtin-v3-1.onrender.com/images/avatars/1.png' %>"
															width="35" height="35" />
													</div>
													<div class="flex-grow-1">
														<div class="d-flex justify-content-between align-items-center">
															<h6 class="mb-0 small"><%= reply.TaiKhoan.HoVaTen %></h6>
															<time class="small text-muted" style="font-size: 0.75rem;"><%= new Date(reply.NgayBinhLuan).toLocaleString('vi-VN') %></time>
														</div>
														<p class="mt-1 mb-0 small"><%= reply.NoiDung %></p>
													</div>
												</div>
												<% }); %>
											</div>
										<% } %>
									</div>
									<% }); %>
									
									<div class="mt-5">
										<h5>Để lại bình luận</h5>
										<% if(typeof session !== "undefined" && session.MaNguoiDung) { %>
										<form action="/binhluan/<%= baiviet._id %>" method="post">
											<textarea class="form-control mt-3" rows="3" name="NoiDung" required
												placeholder="Cảm nghĩ của bạn về bài viết này..."></textarea>
											<button type="submit" class="btn btn-success mt-3 w-100">Gửi bình luận</button>
										</form>
										<% } else { %>
										<div class="alert alert-info mt-3">
											Vui lòng <a href="/dangnhap" class="alert-link">đăng nhập</a> để tham gia bình luận.
										</div>
										<% } %>
									</div>
							</div>
						</article>
						<% } %>
				</div>
				<div class="col-md-3 ms-auto">
					<aside class="sidebar">
						<div class="card mb-4">
							<div class="card-body">
								<h4 class="card-title">Giới thiệu</h4>
								<p class="card-text">Đọc tin tức trên trang web này sẽ giúp bạn có cái nhìn khách quan
									về cuộc sống. Đừng quên chia sẻ trang này cho toàn bộ vũ trụ biết nhé. Mến yêu.</p>
							</div>
						</div>
					</aside>
					<aside class="sidebar sidebar-sticky">
						<div class="card mb-4">
							<div class="card-body">
								<h4 class="card-title">Thẻ</h4>
								<% if(typeof chuyenmuc !=="undefined" ) { chuyenmuc.forEach(cd=> { %>
									<a class="btn btn-light btn-sm mb-1" href="/baiviet/chude/<%= cd._id %>">
										<%= cd.TenChuDe %>
									</a>
									<% }); } %>
							</div>
						</div>
						<div class="card mb-4">
							<div class="card-body">
								<h4 class="card-title">Xem nhiều nhất</h4>
								<% if(typeof xemnhieunhat !=="undefined" ) { xemnhieunhat.forEach(bv=> { %>
									<a href="/baiviet/chitiet/<%= bv._id %>" class="d-inline-block mt-3">
										<h4 class="h6">
											<%= bv.TieuDe %>
										</h4>
										<img class="card-img-post w-100" src="<%- firstImage(bv.NoiDung) %>" alt="" />
									</a>
									<time class="timeago" datetime="<%= bv.NgayDang %>"></time> thuộc <%=
										bv.ChuDe ? bv.ChuDe.TenChuDe : 'Chưa phân loại' %>
										<% }); } %>
							</div>
						</div>
					</aside>
				</div>
			</div>
		</div>
	</main>
	<%- include('footer_public') %>
	<script src="/js/app.js"></script>
	<script src="/js/weather.js"></script>
</body>

</html>