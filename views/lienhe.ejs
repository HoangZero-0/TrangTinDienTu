<!DOCTYPE html>
<html lang="en">

<head>
	<meta charset="utf-8" />
	<meta http-equiv="X-UA-Compatible" content="IE=edge" />
	<meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
	<meta name="description" content="Trang tin điện tử nhiều người xem nhất vũ trụ." />
	<meta name="author" content="Nguyễn Hoàng Thức & Lê Nhật Quang" />
	<title>
		<%= title %> - Trang tin điện tử
	</title>
	<link href="/css/app.css" rel="stylesheet" />
	<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.8.1/font/bootstrap-icons.css">
	<style>
		html, body {
			height: 100%;
		}
		body {
			display: flex;
			flex-direction: column;
		}
		.main {
			flex: 1 0 auto;
		}
		.site-footer {
			flex-shrink: 0;
		}
		.contact-content {
			max-width: fit-content;
			margin: 0 auto;
			text-align: left;
			word-break: break-word;
		}
	</style>
</head>

<body>
	<%- include('navbar_public') %>
	<main class="main pt-4">
		<div class="container">
			<div class="row">
				<div class="col-md-8 mx-auto">
					<article class="card mb-4 border-0">
						<header class="card-header text-center bg-white border-0">
							<h1 class="card-title">Liên hệ với chúng tôi</h1>
						</header>
						<div class="card-body">
							<div class="contact-content">
								<h5 class="text-center mb-4">Thông tin liên hệ</h5>
								<p><strong>Địa chỉ:</strong> 123 Đường ABC, Long Xuyên, An Giang</p>
								<p><strong>Email:</strong> <br>
									<a href="mailto:thuc_dpm225488@student.agu.edu.vn">thuc_dpm225488@student.agu.edu.vn</a><br>
									<a href="mailto:quang_dpm225460@student.agu.edu.vn">quang_dpm225460@student.agu.edu.vn</a>
								</p>
								<p><strong>Điện thoại:</strong> <a href="tel:0123456789">0123456789</a></p>
								<p><strong>Thời gian làm việc:</strong> 8:00 - 17:00 (Thứ 2 - Thứ 6)</p>
							</div>
						</div>
					</article>
				</div>
			</div>
		</div>
	</main>
	<%- include('footer_public') %>
	<script src="/js/app.js"></script>
	<script src="/js/weather.js"></script>
</body>

</html>
