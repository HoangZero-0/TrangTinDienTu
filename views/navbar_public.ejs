<div class="sticky-header-wrapper">
	<header>
		<nav class="navbar navbar-expand-md navbar-light bg-white absolute-top">
			<div class="container">
				<button class="navbar-toggler order-2 order-md-1" type="button" data-bs-toggle="collapse"
					data-bs-target=".navbar-collapse" aria-controls="navbar-left navbar-right" aria-expanded="false"
					aria-label="Toggle navigation">
					<span class="navbar-toggler-icon"></span>
				</button>
				<div class="collapse navbar-collapse order-3 order-md-2" id="navbar-left">
					<ul class="navbar-nav me-auto">
						<li class="nav-item dropdown active">
							<a class="nav-link dropdown-toggle" href="#" id="chuyenmuc" data-bs-toggle="dropdown"
								aria-haspopup="true" aria-expanded="false">Chuyên mục</a>
							<div class="dropdown-menu" aria-labelledby="chuyenmuc">
								<% if(typeof chuyenmuc !=="undefined" ) { chuyenmuc.forEach(cd=> { %>
									<a class="dropdown-item" href="/baiviet/chude/<%= cd._id %>">
										<%= cd.TenChuDe %>
									</a>
									<% }); } %>
							</div>
						</li>
					</ul>
				</div>
				<a class="navbar-brand mx-auto order-1 order-md-3" href="/">iNews</a>
				<div class="collapse navbar-collapse order-4 order-md-4" id="navbar-right">
					<ul class="navbar-nav ms-auto">
						<% if(typeof session==="undefined" || !session.MaNguoiDung) { %>
							<li class="nav-item">
								<a class="nav-link" href="/dangky">Đăng ký</a>
							</li>
							<li class="nav-item">
								<a class="nav-link" href="/dangnhap">Đăng nhập</a>
							</li>
							<% } else { %>
								<li class="nav-item dropdown">
									<a class="nav-link dropdown-toggle d-flex align-items-center" href="#" id="navbarUser" data-bs-toggle="dropdown">
										<img src="<%= session.HinhAnh || 'https://trangtin-v3-1.onrender.com/images/avatars/1.png' %>" class="img-avatar-nav me-1" />
										<span><%= session.HoVaTen %></span>
									</a>
									<div class="dropdown-menu dropdown-menu-end" aria-labelledby="navbarUser">
										<a class="dropdown-item" href="/baiviet/daluu"><i class="bi bi-heart me-2"></i>Đã lưu</a>
										<a class="dropdown-item" href="/taikhoan/hoso"><i class="bi bi-person me-2"></i>Hồ sơ</a>
										<a class="dropdown-item" href="/admin"><i class="bi bi-speedometer2 me-2"></i>Quản lý</a>
										<div class="dropdown-divider"></div>
										<a class="dropdown-item text-danger" href="/dangxuat"><i class="bi bi-box-arrow-right me-2"></i>Đăng xuất</a>
									</div>
								</li>
								<% } %>
					</ul>
					<form class="form-inline" role="search" action="/timkiem" method="get">
						<input name="tukhoa" class="search js-search form-control form-control-rounded me-sm-2"
							type="text" title="Bạn muốn tìm gì?" placeholder="Tìm kiếm..." aria-label="Search" />
					</form>
				</div>
			</div>
		</nav>
	</header>
</div>
