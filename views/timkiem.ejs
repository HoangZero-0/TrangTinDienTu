<!DOCTYPE html>
<html lang="en">

<head>
	<meta charset="utf-8" />
	<meta http-equiv="X-UA-Compatible" content="IE=edge" />
	<meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
	<meta name="description" content="Trang tin điện tử nhiều người xem nhất vũ trụ." />
	<meta name="author" content="Nguyễn Hoàng Thức & Lê Nhật Quang" />
	<title>
		<%= title %> - Trang tin điện tử
	</title>
	<link href="/css/app.css" rel="stylesheet" />
	<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.8.1/font/bootstrap-icons.css">
</head>

<body>
	<%- include('navbar_public') %>
	<main class="main pt-4">
		<div class="container">
			<div class="row">
				<div class="col-md-9">
					<div class="text-center">
						<h3>Kết quả tìm kiếm</h3>
						<hr />
					</div>
					<% if(baiviet.length > 0) { %>
						<% baiviet.forEach(bv => { %>
						<article class="card mb-4 border-0 shadow-sm">
							<div class="row g-0 align-items-start">
								<div class="col-md-4">
									<a href="/baiviet/chitiet/<%= bv._id %>">
										<img class="img-fluid rounded-start w-100" style="height: 160px; object-fit: cover;" src="<%- firstImage(bv.NoiDung) %>" alt="<%= bv.TieuDe %>" />
									</a>
								</div>
								<div class="col-md-8">
									<div class="card-body py-2">
										<div class="card-meta mb-1" style="font-size: 0.8rem;">
											<span class="text-muted"><time class="timeago" datetime="<%= bv.NgayDang %>"></time></span>
											<span class="mx-1">|</span>
											<a href="/baiviet/chude/<%= bv.ChuDe ? bv.ChuDe._id : '#' %>" class="text-primary text-decoration-none">
												<%= bv.ChuDe ? bv.ChuDe.TenChuDe : 'Chưa phân loại' %>
											</a>
										</div>
										<a href="/baiviet/chitiet/<%= bv._id %>" class="text-dark text-decoration-none">
											<h5 class="card-title mb-2 fw-bold"><%= bv.TieuDe %></h5>
										</a>
										<p class="card-text text-muted small mb-0">
											<%= bv.TomTat.substring(0, 150) %>...
										</p>
									</div>
								</div>
							</div>
						</article>
						<% }); %>
					<% } else { %>
						<div class="alert alert-primary" role="alert">
							<h4 class="alert-heading">Rất tiếc!</h4>
							<p>Không tìm thấy bài viết nào phù hợp với từ khóa "<strong><%= tukhoa %></strong>".</p>
							<hr>
							<div class="btn-list">
								<a class="btn btn-primary" type="button" href="/">Về trang chủ</a>
							</div>
						</div>
					<% } %>
				</div>
				<div class="col-md-3 ms-auto">
					<aside class="sidebar">
						<div class="card mb-4">
							<div class="card-body">
								<h4 class="card-title">Giới thiệu</h4>
								<p class="card-text">Đọc tin tức trên trang web này sẽ giúp bạn có cái nhìn khách quan
									về cuộc sống. Đừng quên chia sẻ trang này cho toàn bộ vũ trụ biết nhé. Mến yêu.</p>
							</div>
						</div>
					</aside>
					<aside class="sidebar sidebar-sticky">
						<div class="card mb-4">
							<div class="card-body">
								<h4 class="card-title">Thẻ</h4>
								<% if(typeof chuyenmuc !=="undefined" ) { chuyenmuc.forEach(cd=> { %>
									<a class="btn btn-light btn-sm mb-1" href="/baiviet/chude/<%= cd._id %>">
										<%= cd.TenChuDe %>
									</a>
									<% }); } %>
							</div>
						</div>
						<div class="card mb-4">
							<div class="card-body">
								<h4 class="card-title">Xem nhiều nhất</h4>
								<% if(typeof xemnhieunhat !=="undefined" ) { xemnhieunhat.forEach(bv=> { %>
									<a href="/baiviet/chitiet/<%= bv._id %>" class="d-inline-block mt-3">
										<h4 class="h6">
											<%= bv.TieuDe %>
										</h4>
										<img class="card-img" src="<%- firstImage(bv.NoiDung) %>" alt="" />
									</a>
									<time class="timeago" datetime="<%= bv.NgayDang %>"></time> thuộc <%=
										bv.ChuDe ? bv.ChuDe.TenChuDe : 'Chưa phân loại' %>
										<% }); } %>
							</div>
						</div>
					</aside>
				</div>
			</div>
		</div>
	</main>
	<%- include('footer_public') %>
	<script src="/js/app.js"></script>
	<script src="/js/weather.js"></script>
</body>

</html>