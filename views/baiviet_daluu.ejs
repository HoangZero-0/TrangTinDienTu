<!DOCTYPE html>
<html lang="en">

<head>
	<meta charset="utf-8" />
	<meta http-equiv="X-UA-Compatible" content="IE=edge" />
	<meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
	<meta name="description" content="Trang tin điện tử nhiều người xem nhất vũ trụ." />
	<meta name="author" content="Nguyễn Hoàng Thức & Lê Nhật Quang" />
	<title>
		<%= title %> - Trang tin điện tử
	</title>
	<link href="/css/app.css" rel="stylesheet" />
	<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.8.1/font/bootstrap-icons.css">
</head>

<body>
	<%- include('navbar_public') %>
	<main class="main pt-4">
		<div class="container">
			<div class="row justify-content-center">
				<div class="col-md-11">
					<h2 class="mb-4"><%= title %></h2>
					<div class="row">
						<% if(baiviet.length === 0) { %>
							<div class="col-12 text-center mt-5">
								<i class="bi bi-heart text-muted" style="font-size: 3rem;"></i>
								<p class="mt-3 text-muted">Bạn chưa lưu bài viết nào.</p>
								<a href="/" class="btn btn-primary">Khám phá tin tức</a>
							</div>
						<% } else { %>
							<% baiviet.forEach(bv => { %>
								<div class="col-md-3">
									<article class="card mb-4 border-0 shadow-sm h-100">
										<a href="/baiviet/chitiet/<%= bv._id %>">
											<img class="card-img-top" src="<%- firstImage(bv.NoiDung) %>" style="height: 150px; object-fit: cover;" />
										</a>
										<div class="card-body p-3">
											<div class="card-meta small mb-2">
												<time class="timeago" datetime="<%= bv.NgayDang %>"></time>
											</div>
											<h5 class="card-title h6 mb-3">
												<a href="/baiviet/chitiet/<%= bv._id %>" class="text-decoration-none text-dark">
													<%= bv.TieuDe %>
												</a>
											</h5>
											<form action="/baiviet/luu/<%= bv._id %>" method="POST">
												<button type="submit" class="btn btn-sm btn-link p-0 text-danger text-decoration-none">
													<i class="bi bi-heart-fill"></i> Bỏ lưu
												</button>
											</form>
										</div>
									</article>
								</div>
							<% }); %>
						<% } %>
					</div>
				</div>
			</div>
		</div>
	</main>
	<%- include('footer_public') %>
	<script src="/js/app.js"></script>
	<script src="/js/weather.js"></script>
</body>

</html>
