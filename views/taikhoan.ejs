<!DOCTYPE html>
<html lang="en">

<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1" />
	<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
	<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
	<title><%= title %> - Trang tin điện tử</title>
</head>

<body>
	<div class="container">
		<!-- Menu ngang -->
		<%- include('navbar') %>
		
		<!-- Nội dung chính -->
		<div class="card mt-3">
			<div class="card-header"><%= title %></div>
			<div class="card-body table-responsive">
				<div class="row mb-2">
					<div class="col-md-8">
						<a href="/taikhoan/them" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Thêm mới</a>
					</div>
					<div class="col-md-4">
						<div class="input-group">
							<input type="text" id="searchFilter" class="form-control" placeholder="Tìm kiếm tài khoản...">
							<button class="btn btn-outline-secondary" type="button" id="btnSearch"><i class="bi bi-search"></i></button>
						</div>
					</div>
				</div>
				<table class="table table-bordered table-hover table-sm mb-0">
					<thead>
						<tr>
							<th width="5%">#</th>
							<th>Họ và tên</th>
							<th>Email</th>
							<th>Hình ảnh</th>
							<th>Tên đăng nhập</th>
							<th>Quyền hạn</th>
							<th>Trạng thái</th>
							<th width="5%">Sửa</th>
							<th width="5%">Xóa</th>
						</tr>
					</thead>
					<tbody>
						<% if(taikhoan.length === 0) { %>
							<tr>
								<td colspan="9" class="text-center text-muted">Chưa có tài khoản nào.</td>
							</tr>
						<% } else { %>
							<% var stt = 1; %>
							<% taikhoan.forEach(tk => { %>
								<tr>
									<td class="align-middle text-center"><%= stt++ %></td>
									<td class="align-middle"><%= tk.HoVaTen %></td>
									<td class="align-middle"><%= tk.Email %></td>
									<td class="align-middle text-center">
										<img src="<%= tk.HinhAnh ? tk.HinhAnh : '/images/noimage.png' %>" width="30" height="30" class="rounded-circle border" />
									</td>
									<td class="align-middle"><%= tk.TenDangNhap %></td>
									<td class="align-middle"><span class="badge <%= tk.QuyenHan === 'admin' ? 'bg-danger' : 'bg-info text-dark' %>"><%= tk.QuyenHan %></span></td>
									<td class="align-middle text-center">
										<% if(tk.KichHoat == 1) { %>
											<i class="bi bi-check-circle text-success" title="Đang hoạt động"></i>
										<% } else { %>
											<i class="bi bi-x-square text-danger" title="Bị khóa"></i>
										<% } %>
									</td>
									<td class="align-middle text-center">
										<a href="/taikhoan/sua/<%= tk._id %>"><i class="bi bi-pencil-square"></i></a>
									</td>
									<td class="align-middle text-center">
										<% if(tk._id == session.MaNguoiDung) { %>
											<button type="button" class="btn btn-sm btn-link p-0" onclick="alert('Không thể tự xóa tài khoản của chính mình!');"><i class="bi bi-trash text-muted"></i></button>
										<% } else { %>
											<form action="/taikhoan/xoa/<%= tk._id %>" method="POST" style="display:inline;" onsubmit="return confirm('Bạn có muốn xóa tài khoản <%= tk.HoVaTen %> không?');">
												<button type="submit" class="btn btn-sm btn-link p-0"><i class="bi bi-trash text-danger"></i></button>
											</form>
										<% } %>
									</td>
								</tr>
							<% }); %>
						<% } %>
					</tbody>
				</table>
			</div>
		</div>
		
		<!-- Footer -->
		<%- include('footer') %>
	</div>
	
	<%- include('javascript') %>
</body>

</html>